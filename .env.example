# Server settings
PORT=4000
API_KEY=your_api_key_here

# SMTP settings (for sending emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=info@yourdomain.com

# Optional: Use AWS S3 for storing uploaded PDFs
USE_S3=false
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Frontend base URL (if different from server)
FRONTEND_URL=http://localhost:5173

# Firebase (client) - values used by the frontend (Vite must expose VITE_ variables)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase (server) - optional: upload files to Firebase Storage from the helper server
# Either set FIREBASE_SERVICE_ACCOUNT_JSON to the JSON string of a service account, or
# set FIREBASE_SERVICE_ACCOUNT_PATH to a local path to the service account JSON file.
USE_FIREBASE_STORAGE=false
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com
